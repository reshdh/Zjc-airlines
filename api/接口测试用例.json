  },
  "testSuites": [
    {
      "name": "基础连通性测试",
      "testCases": ["1", "2", "3", "10", "12"]
    },
    {
      "name": "座位选择功能测试（新增）",
      "testCases": ["4", "5", "6", "7"]
    },
    {
      "name": "预订功能测试（含座位选择）",
