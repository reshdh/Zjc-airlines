    "3_搜索航班_按出发地和目的地": {
      "request": {
        "method": "POST",
        "url": "http://localhost:8080/api/flights/search",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "origin": "北京",
          "destination": "上海"
