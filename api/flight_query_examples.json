  "字段说明": {
    "航班字段": {
      "id": "航班ID",
      "flightNumber": "航班号",
      "aircraftType": "机型",
      "origin": "出发地",
      "destination": "目的地",
      "departureTime": "出发时间（ISO 8601格式）",
      "arrivalTime": "到达时间（ISO 8601格式）",
      "createdAt": "创建时间",
      "updatedAt": "更新时间",
      "seats": "舱位信息数组"
    },
    "舱位字段": {
      "id": "舱位ID",
      "cabinClass": "舱位等级（ECONOMY-经济舱，BUSINESS-商务舱，FIRST-头等舱）",
      "price": "该舱位票价（元）",
      "remainingSeats": "剩余座位数",
      "totalSeats": "总座位数",
      "createdAt": "创建时间",
      "updatedAt": "更新时间"
    }
  }
}


